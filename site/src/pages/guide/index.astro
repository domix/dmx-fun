---
import DocsLayout from '../../layouts/DocsLayout.astro';
const base = import.meta.env.BASE_URL;

const tagColor: Record<string, string> = {
    'Nullability':          'blue',
    'Error handling':       'amber',
    'Exception handling':   'red',
    'Validation':           'green',
    'Disjoint union':       'purple',
    'Deferred computation': 'teal',
    'Product types':        'cyan',
    'Collections':          'violet',
    'Tracing':              'indigo',
    'Resource management':  'orange',
    'Interop':              'gray',
    'JSON':                 'gray',
    'Testing':              'gray',
    'Spring':               'gray',
    'Quarkus':              'gray',
    'Resilience':           'gray',
    'Observability':        'gray',
    'HTTP':                 'gray',
    'Serialization':        'gray',
    'Contributors':         'gray',
    'Maintainers':          'gray',
};

const types = [
    { name: 'Option<T>',        href: `${base}guide/option`,           summary: 'A value that may or may not be present. The null-safe alternative.',                                                                           whenToUse: 'You have an optional field or a lookup that may yield no result.',                                                                                  avoidWhen: 'The absence carries meaning beyond "not found" — use Result instead.',                                              tag: 'Nullability' },
    { name: 'Result<V, E>',     href: `${base}guide/result`,           summary: 'Either a success value or a typed error. Models domain failures explicitly.',                                                                   whenToUse: 'An operation can fail and the caller needs to handle the error type.',                                                                               avoidWhen: 'The error is always an exception message string — Try is simpler.',                                                  tag: 'Error handling' },
    { name: 'Try<V>',           href: `${base}guide/try`,              summary: 'Wraps a computation that may throw. Turns exceptions into values.',                                                                              whenToUse: 'You are calling legacy or third-party code that throws checked/runtime exceptions.',                                                                 avoidWhen: 'You own the error type and want callers to branch on it — use Result.',                                              tag: 'Exception handling' },
    { name: 'Validated<E, A>',  href: `${base}guide/validated`,        summary: 'Like Result but accumulates multiple errors instead of failing fast.',                                                                           whenToUse: 'You want to collect all validation errors at once (e.g. a form submission).',                                                                        avoidWhen: 'You only care about the first failure — Result short-circuits and is simpler.',                                      tag: 'Validation' },
    { name: 'Either<L, R>',     href: `${base}guide/either`,           summary: 'A neutral disjoint union with no success/failure semantics.',                                                                                    whenToUse: 'You need a branching value where neither side is inherently an error.',                                                                              avoidWhen: 'One side clearly represents failure — use Result for that semantic clarity.',                                        tag: 'Disjoint union' },
    { name: 'Lazy<T>',          href: `${base}guide/lazy`,             summary: 'A value computed at most once, on first access. Thread-safe memoization.',                                                                       whenToUse: 'You have an expensive computation you want to defer and cache.',                                                                                     avoidWhen: 'The value is cheap to produce — the overhead of wrapping it is not worth it.',                                       tag: 'Deferred computation' },
    { name: 'Tuple2/3/4',       href: `${base}guide/tuples`,           summary: 'Typed heterogeneous tuples. Named fields without a dedicated class.',                                                                            whenToUse: 'You need to return 2–4 values from a method without a dedicated record.',                                                                            avoidWhen: 'The tuple has stable semantics — model it as a proper record instead.',                                              tag: 'Product types' },
    { name: 'NonEmptyList<T>',  href: `${base}guide/non-empty-list`,   summary: 'A list guaranteed to have at least one element at compile time.',                                                                                whenToUse: 'An API contract requires at least one element and you want to enforce it in the type.',                                                              avoidWhen: 'Emptiness is a valid state — use a regular List.',                                                                   tag: 'Collections' },
    { name: 'NonEmptyMap<K,V>', href: `${base}guide/non-empty-map`,    summary: 'A map guaranteed to have at least one entry at compile time. Insertion order preserved.',                                                        whenToUse: 'A registry, configuration, or lookup table that must always contain at least one entry.',                                                            avoidWhen: 'Emptiness is a valid state — use a regular Map.',                                                                    tag: 'Collections' },
    { name: 'NonEmptySet<T>',   href: `${base}guide/non-empty-set`,    summary: 'A set guaranteed to have at least one element at compile time. No duplicates, insertion order preserved.',                                       whenToUse: 'Set semantics (no duplicates) with the guarantee of non-emptiness, e.g. user roles or product tags.',                                               avoidWhen: 'Emptiness is a valid state — use a regular Set.',                                                                    tag: 'Collections' },
    { name: 'Guard<T>',         href: `${base}guide/guard`,            summary: 'A composable, named predicate that produces a Validated result — the reusable building block for validation pipelines.',                        whenToUse: 'You have repeated if/invalidNel validation patterns that should be defined once and composed declaratively.',                                        avoidWhen: 'A single ad-hoc check is simpler — Guard shines when rules are reused or composed.',                                 tag: 'Validation' },
    { name: 'Resource<T>',      href: `${base}guide/resource`,         summary: 'A composable managed resource: acquire, use, and release with a guaranteed cleanup.',                                                            whenToUse: 'You need to bracket an operation around a resource (file, connection, lock) and want to compose multiple resources safely.',                         avoidWhen: 'A simple try-with-resources block suffices and no composition is needed.',                                           tag: 'Resource management' },
    { name: 'Accumulator<E,A>', href: `${base}guide/accumulator`,      summary: 'A value paired with a side-channel accumulation (log, metrics, audit trail). The functional alternative to mutable shared state.',              whenToUse: 'You need to thread log entries, counters, or audit events through a pure computation chain without shared mutable state.',                           avoidWhen: 'A step can fail — use Result for error handling, or Validated to accumulate validation errors.',                     tag: 'Tracing' },
    { name: 'Checked interfaces', href: `${base}guide/checked-interfaces`, summary: 'Checked variants of Function, Supplier, Consumer, Runnable, plus TriFunction/QuadFunction.',                                               whenToUse: 'You need to pass lambdas that throw checked exceptions to higher-order functions.',                                                                   avoidWhen: 'The lambda does not throw — use the standard java.util.function types.',                                             tag: 'Interop' },
];

const modules = [
    { name: 'Jackson',              href: `${base}guide/jackson`,             summary: 'Serializers and deserializers for all dmx-fun types via the optional fun-jackson module.',                                                                                                                                                       tag: 'JSON' },
    { name: 'AssertJ',              href: `${base}guide/assertj`,             summary: 'Fluent AssertJ custom assertions for Option, Result, Try, Validated, and Tuple types.',                                                                                                                                                          tag: 'Testing' },
    { name: 'Spring',               href: `${base}guide/spring`,              summary: 'TxResult and TxTry: programmatic transaction support that rolls back when Result.isError() or Try.isFailure(), without relying on exceptions.',                                                                                                  tag: 'Spring' },
    { name: 'Quarkus',              href: `${base}guide/quarkus`,             summary: 'TxResult and TxTry: CDI transaction support that rolls back when Result.isError() or Try.isFailure(). Declarative @TransactionalResult and @TransactionalTry via a CDI interceptor.',                                                           tag: 'Quarkus' },
    { name: 'Resilience4J',         href: `${base}guide/resilience4j`,        summary: 'Adapters for Retry, CircuitBreaker, RateLimiter, and Bulkhead that return Try or Result instead of throwing exceptions.',                                                                                                                         tag: 'Resilience' },
    { name: 'Micrometer',           href: `${base}guide/micrometer`,          summary: 'Automatic counters, timers, and failure metrics for Try and Result executions via DmxMicrometer.',                                                                                                                                               tag: 'Observability' },
    { name: 'Micrometer Tracing',   href: `${base}guide/tracing`,             summary: 'Automatic distributed tracing spans for Try and Result executions via DmxTracing.',                                                                                                                                                              tag: 'Observability' },
    { name: 'Micrometer Observation', href: `${base}guide/observation`,       summary: 'Metrics and distributed tracing spans for Try and Result executions — both signals from a single DmxObservation call.',                                                                                                                          tag: 'Observability' },
    { name: 'Jakarta Validation',   href: `${base}guide/jakarta-validation`,  summary: 'DmxValidator bridges Jakarta Bean Validation with Validated<NonEmptyList<E>, A> so all constraint violations accumulate without throwing ConstraintViolationException.',                                                                         tag: 'Validation' },
    { name: 'Jakarta JSON-B + JAXB', href: `${base}guide/jakarta-jaxb`,      summary: 'JsonbAdapter and XmlAdapter implementations for all dmx-fun types via the optional fun-jakarta-jaxb module.',                                                                                                                                    tag: 'Serialization' },
    { name: 'HTTP Client',          href: `${base}guide/http`,                summary: 'Wraps java.net.http.HttpClient so every call returns Result<T, HttpError> with typed variants for 4xx, 5xx, timeouts, and network failures.',                                                                                                    tag: 'HTTP' },
];

const contributing = [
    { name: 'Contributing',       href: `${base}guide/contributing`,     summary: 'Prerequisites, local build, code conventions, and how to open a PR.',        tag: 'Contributors' },
    { name: 'CI/CD Pipelines',    href: `${base}guide/pipelines`,        summary: 'All six GitHub Actions workflows: triggers, secrets, local equivalents.',     tag: 'Maintainers' },
    { name: 'Release Process',    href: `${base}guide/release-process`,  summary: 'Step-by-step guide for cutting a stable release.',                            tag: 'Maintainers' },
    { name: 'New Module',         href: `${base}guide/module-conventions`, summary: 'Conventions and checklist for adding a new optional integration module.',   tag: 'Maintainers' },
];

const decisions = [
    { q: 'Value may or may not exist?',              type: 'Option&lt;T&gt;',       href: `${base}guide/option`,           tag: 'Nullability' },
    { q: 'Operation can fail with a typed reason?',  type: 'Result&lt;V,&nbsp;E&gt;', href: `${base}guide/result`,         tag: 'Error handling' },
    { q: 'Wraps legacy code that throws?',           type: 'Try&lt;V&gt;',          href: `${base}guide/try`,              tag: 'Exception handling' },
    { q: 'Collect all validation errors at once?',   type: 'Validated&lt;E,&nbsp;A&gt;', href: `${base}guide/validated`,  tag: 'Validation' },
    { q: 'Branch with no success/failure semantics?', type: 'Either&lt;L,&nbsp;R&gt;', href: `${base}guide/either`,       tag: 'Disjoint union' },
    { q: 'Defer and cache an expensive computation?', type: 'Lazy&lt;T&gt;',        href: `${base}guide/lazy`,             tag: 'Deferred computation' },
];
---

<DocsLayout
    title="Developer Guide"
    description="In-depth reference for every dmx-fun type: when to use it, how it composes, and common pitfalls."
>
  <!-- ── Hero ─────────────────────────────────────────── -->
  <div class="hero">
    <div class="hero-text">
      <h1>Developer Guide</h1>
      <p class="hero-sub">
        Deep reference for every type in dmx-fun: design rationale, every combinator,
        composition patterns, and pitfalls to avoid.
      </p>
    </div>
    <div class="hero-actions">
      <a href={`${base}guide/introduction`} class="btn-primary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
        Start with Introduction
      </a>
      <a href={`${base}guide/combining-types`} class="btn-secondary">
        Type composition →
      </a>
    </div>
  </div>

  <!-- ── Quick nav pills ──────────────────────────────── -->
  <div class="quick-nav" role="navigation" aria-label="Quick type navigation">
    {types.slice(0, 8).map(t => (
      <a href={t.href} class={`quick-pill color-${tagColor[t.tag]}`}>
        <code>{t.name}</code>
      </a>
    ))}
  </div>

  <!-- ── Which type? ──────────────────────────────────── -->
  <section class="section">
    <h2 class="section-heading">
      <span class="section-icon">⚡</span>
      Which type should I use?
    </h2>
    <div class="decision-table">
      {decisions.map(d => (
        <a href={d.href} class="decision-row">
          <span class="decision-q" set:html={d.q} />
          <span class={`decision-badge color-${tagColor[d.tag]}`} set:html={`<code>${d.type}</code>`} />
        </a>
      ))}
    </div>
  </section>

  <!-- ── Type overview ────────────────────────────────── -->
  <section class="section">
    <h2 class="section-heading">
      <span class="section-icon">📦</span>
      Core types
    </h2>
    <div class="card-grid">
      {types.map(t => (
        <a href={t.href} class={`type-card accent-${tagColor[t.tag]}`}>
          <div class="card-header">
            <code class="card-name">{t.name}</code>
            <span class={`card-tag color-${tagColor[t.tag]}`}>{t.tag}</span>
          </div>
          <p class="card-summary">{t.summary}</p>
          <div class="card-meta">
            <div class="meta-row">
              <span class="meta-label use">Use when</span>
              <span class="meta-text">{t.whenToUse}</span>
            </div>
            <div class="meta-row">
              <span class="meta-label avoid">Avoid when</span>
              <span class="meta-text">{t.avoidWhen}</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- ── Composition callout ──────────────────────────── -->
  <a href={`${base}guide/combining-types`} class="composition-callout">
    <div class="callout-text">
      <strong>Cross-type composition</strong>
      <span>
        Every type converts to the others. The Combining Types page covers the full
        conversion matrix, railway-oriented pipelines, and parallel validation patterns.
      </span>
    </div>
    <span class="callout-arrow">→</span>
  </a>

  <!-- ── Modules ──────────────────────────────────────── -->
  <section class="section">
    <h2 class="section-heading">
      <span class="section-icon">🔌</span>
      Integration modules
    </h2>
    <p class="section-desc">
      Optional artifacts — add only what you need. Each module declares its peer dependency
      as <code>compileOnly</code> so it never pulls in transitive dependencies unexpectedly.
    </p>
    <div class="card-grid module-grid">
      {modules.map(m => (
        <a href={m.href} class={`type-card accent-${tagColor[m.tag]}`}>
          <div class="card-header">
            <code class="card-name">{m.name}</code>
            <span class={`card-tag color-${tagColor[m.tag]}`}>{m.tag}</span>
          </div>
          <p class="card-summary">{m.summary}</p>
        </a>
      ))}
    </div>
  </section>

  <!-- ── Contributing ─────────────────────────────────── -->
  <section class="section">
    <h2 class="section-heading">
      <span class="section-icon">🛠</span>
      Contributing &amp; Maintainer
    </h2>
    <div class="contrib-grid">
      {contributing.map(c => (
        <a href={c.href} class="contrib-card">
          <div class="card-header">
            <strong class="contrib-name">{c.name}</strong>
            <span class="card-tag color-gray">{c.tag}</span>
          </div>
          <p class="card-summary">{c.summary}</p>
        </a>
      ))}
    </div>
  </section>
</DocsLayout>

<style>
  /* ── Hero ─────────────────────────────────────────────── */
  .hero {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 2rem;
    padding: 2.5rem 0 2rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }

  .hero h1 {
    font-size: 2.5rem;
    font-weight: 800;
    line-height: 1.15;
    margin: 0 0 0.75rem;
    background: linear-gradient(135deg, var(--color-primary), #6366f1);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-sub {
    margin: 0;
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    max-width: 540px;
  }

  .hero-actions {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    flex-shrink: 0;
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1.25rem;
    background-color: var(--color-primary);
    color: white;
    border-radius: 8px;
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 600;
    transition: background-color 0.15s, transform 0.15s;
    white-space: nowrap;
  }

  .btn-primary:hover {
    background-color: var(--color-primary-hover);
    transform: translateY(-1px);
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    padding: 0.625rem 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    text-decoration: none;
    color: var(--color-text);
    font-size: 0.875rem;
    font-weight: 500;
    transition: border-color 0.15s, color 0.15s;
    white-space: nowrap;
  }

  .btn-secondary:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  /* ── Quick nav ────────────────────────────────────────── */
  .quick-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2.5rem;
  }

  .quick-pill {
    display: inline-flex;
    align-items: center;
    padding: 0.3rem 0.75rem;
    border-radius: 20px;
    border: 1px solid transparent;
    text-decoration: none;
    font-size: 0.8rem;
    transition: opacity 0.15s, transform 0.15s;
  }

  .quick-pill:hover { opacity: 0.8; transform: translateY(-1px); }
  .quick-pill code { font-size: inherit; background: none; padding: 0; }

  /* ── Sections ─────────────────────────────────────────── */
  .section {
    margin-bottom: 3rem;
  }

  .section-heading {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 1.25rem;
    font-weight: 700;
    margin: 0 0 1rem;
    padding-bottom: 0.625rem;
    border-bottom: 1px solid var(--color-border);
    color: var(--color-text);
  }

  .section-icon {
    font-size: 1.1rem;
    line-height: 1;
  }

  .section-desc {
    margin: 0 0 1.25rem;
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  /* ── Decision table ───────────────────────────────────── */
  .decision-table {
    border: 1px solid var(--color-border);
    border-radius: 10px;
    overflow: hidden;
  }

  .decision-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.875rem 1.25rem;
    text-decoration: none;
    color: var(--color-text);
    border-bottom: 1px solid var(--color-border);
    transition: background-color 0.15s;
    flex-wrap: wrap;
  }

  .decision-row:last-child { border-bottom: none; }

  .decision-row:hover { background-color: var(--color-surface); }

  .decision-q {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    flex: 1;
    min-width: 200px;
  }

  .decision-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.75rem;
    border-radius: 6px;
    border: 1px solid transparent;
    font-size: 0.8rem;
    font-weight: 600;
    white-space: nowrap;
  }

  .decision-badge code { background: none; padding: 0; font-size: inherit; font-weight: 700; }

  /* ── Cards grid ───────────────────────────────────────── */
  .card-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .module-grid {
    grid-template-columns: repeat(3, 1fr);
  }

  .type-card {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    padding: 1.125rem;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    text-decoration: none;
    color: inherit;
    background-color: var(--color-surface);
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
    position: relative;
    overflow: hidden;
  }

  .type-card::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 3px;
    opacity: 0;
    transition: opacity 0.2s;
    border-radius: 10px 0 0 10px;
  }

  .type-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px var(--color-shadow);
  }

  .type-card:hover::before { opacity: 1; }

  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .card-name {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--color-primary);
  }

  .card-tag {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    border: 1px solid transparent;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .card-summary {
    margin: 0;
    font-size: 0.825rem;
    line-height: 1.55;
    color: var(--color-text-secondary);
    flex: 1;
  }

  .card-meta {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding-top: 0.625rem;
    border-top: 1px solid var(--color-border);
    margin-top: auto;
  }

  .meta-row {
    display: flex;
    gap: 0.4rem;
    font-size: 0.75rem;
    line-height: 1.4;
    align-items: baseline;
  }

  .meta-label {
    font-weight: 700;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .meta-label.use   { color: var(--color-primary); }
  .meta-label.avoid { color: var(--color-text-secondary); opacity: 0.7; }

  .meta-text { color: var(--color-text-secondary); }

  /* ── Composition callout ──────────────────────────────── */
  .composition-callout {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1.25rem 1.5rem;
    border: 1px solid var(--color-primary);
    border-radius: 10px;
    text-decoration: none;
    color: var(--color-text);
    margin-bottom: 3rem;
    background: linear-gradient(135deg, rgba(88, 166, 255, 0.05), rgba(99, 102, 241, 0.05));
    transition: background 0.2s, transform 0.2s;
  }

  .composition-callout:hover {
    background: linear-gradient(135deg, rgba(88, 166, 255, 0.1), rgba(99, 102, 241, 0.1));
    transform: translateY(-1px);
  }

  .callout-text {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .callout-text strong {
    font-size: 1rem;
    color: var(--color-primary);
  }

  .callout-text span {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .callout-arrow {
    font-size: 1.5rem;
    color: var(--color-primary);
    font-weight: 300;
    flex-shrink: 0;
  }

  /* ── Contributing grid ────────────────────────────────── */
  .contrib-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  .contrib-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1rem 1.125rem;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    text-decoration: none;
    color: inherit;
    background-color: var(--color-surface);
    transition: border-color 0.2s, transform 0.2s;
  }

  .contrib-card:hover {
    border-color: var(--color-primary);
    transform: translateY(-2px);
  }

  .contrib-name {
    font-size: 0.875rem;
    color: var(--color-text);
  }

  /* ── Color system ─────────────────────────────────────── */
  /* Blue */
  .color-blue { background: rgba(88,166,255,.12); color: #58a6ff; border-color: rgba(88,166,255,.3); }
  .accent-blue:hover { border-color: #58a6ff; }
  .accent-blue::before { background: #58a6ff; }

  /* Amber */
  .color-amber { background: rgba(251,191,36,.12); color: #f59e0b; border-color: rgba(251,191,36,.3); }
  .accent-amber:hover { border-color: #f59e0b; }
  .accent-amber::before { background: #f59e0b; }

  /* Red */
  .color-red { background: rgba(239,68,68,.12); color: #ef4444; border-color: rgba(239,68,68,.3); }
  .accent-red:hover { border-color: #ef4444; }
  .accent-red::before { background: #ef4444; }

